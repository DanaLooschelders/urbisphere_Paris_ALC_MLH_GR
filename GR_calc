abline(h=0.08, col="red",)
abline(h=0.8, col="orange")
dev.off()
#filter derivative to get slop of MT 
imax <- which.max(dy_dx_norm) #find maximum
if(imax!=1){#if the growth rate is increasing over time
dy_dx_norm_after <- dy_dx_norm[(imax+1):length(dy_dx_norm)] #subset to after maximum
MT_start <-  which(dy_dx_norm > threshold_start)[1]
MT_end   <- which(dy_dx_norm_after < threshold_end)[1] + imax
}else{#if the growth rate is decreasing over time
  MT_start <-  1
  MT_end   <- which(dy_dx_norm < threshold_start)[1]
}
#if second threshold is not reached take end (max MLH)
if(is.na(MT_end)==TRUE){ 
  MT_end <- length(dy_dx_norm)
  special_end <- TRUE
}else{special_end <- FALSE }
#subset to MT
dy_dx_MT <- dy_dx[MT_start:MT_end]
#filter data to only contain MT 
test_MT <- test[c(FALSE, MT_start:MT_end),]
#write results into output data frame
#max growth rate
res_GR$max_GR[res_GR$Site==x&res_GR$Date==i] <- max(dy_dx_MT, na.rm=T)*4 
#res_GR$avg_GR[res_GR$Site==x&res_GR$Date==i] <- mean(dy_dx_MT, na.rm=T)*4 
#mean growth rate
res_GR$avg_GR[res_GR$Site==x&res_GR$Date==i] <- (max(test_MT$MLH, na.rm=T)-min(test_MT$MLH, na.rm=T))/
  as.numeric(difftime(max(test_MT$time, na.rm=T), min(test_MT$time, na.rm=T), units = "hours")) 
#get start of MT
res_GR$MT_start[res_GR$Site==x&res_GR$Date==i] <- as.POSIXct(test_MT$time[1], tz="UTC") 
#get end of MT
