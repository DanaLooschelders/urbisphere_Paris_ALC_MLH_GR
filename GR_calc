max_MLH_jit <- max_MLH_sub %>%
  mutate(code = factor(code, levels = rev(names(colors)))) %>%
  group_by(date) %>%
  mutate(x_jit = as.numeric(code) + runif(n(), -0.15, 0.15),  
         rank_GR = as.factor(rank(max_MLH, ties.method = "first"))) %>%       
  #size_rank = scales::rescale(rank_GR, to = c(2, 6))) %>%
  ungroup()

#reorder factor
emm_df$code <- factor(emm_df$code, levels=levels(max_MLH_jit$code))

#calculate sample size
n_df <- max_MLH_jit %>% drop_na(max_MLH) %>% count(code, name = "n") %>%
  mutate(label = paste0("n = ", n), y = max(max_MLH_jit$max_MLH, na.rm = TRUE) * 1.05) 

# Plot with point size
max_MLH_jit  %>% drop_na(max_MLH)  %>% ggplot() +
  #geom_boxplot(aes(x = code, y = MT_z_start), outlier.shape = NA) +
  geom_line(aes(x = x_jit,  y = max_MLH, group = date, color="day"),
            alpha = 0.5, linewidth = 0.6, na.rm = FALSE) +
  geom_point(aes(x = x_jit,  y = max_MLH, size = rank_GR, fill=rank_GR),
             alpha = 0.6, color = "black", shape = 21) +#, fill = "grey70"
  paletteer::scale_fill_paletteer_d(name = "within day",
                                    "colorBlindness::LightBlue2DarkBlue7Steps",
                                    labels=c("Smaller", "", "", "", "", "", "Larger")) +
  scale_color_manual(name = expression(atop(bar(m)~"modelled mean" , "n = sample size   ")),
                     values = c("modelled \nmean" = "black",
                                                         "confidence \nlimits" = "black",
                                                         "day" = "grey70"),
                     limits = c( "modelled \nmean", "confidence \nlimits","day"))+
  scale_x_discrete(labels = function(x) {
    new_names <- c("upwind rural" = "rural",
                   "upwind urban fringe"  = "urban fringe",
                   "upwind outer city"  = "outer city",
                   "inner city" = "inner city",
                   "downwind outer city"  = "outer city",
                   "downwind urban fringe"  = "urban fringe",
                   "downwind rural" = "rural")
    stringr::str_wrap(new_names[x], width = 10)})+
  scale_size_manual(name = "within day", values = c(1, 2, 3, 4, 5, 6,7),
                    labels=c("Smaller", "", "", "", "", "", "Larger")) +
  guides(fill = guide_legend(reverse=T), 
         size = guide_legend(reverse=T))+
  annotate("text", x = Inf, y = Inf, label = "(B)",
           hjust = 1.2, vjust = 1.2, size = 8, fontface = "bold")+
  theme_bw(base_size = 14) + ylab("Maximum MLH (m)")+
  theme(legend.position = "none", axis.title.x = element_blank(), 
        plot.margin = unit(c(0.1, 0.01, 0.01, 0.01), units="npc"),
        text=element_text(size=18), legend.title=element_text(size=14))+
  geom_point(data = emm_df, aes(x = code, y = emmean, colour = "modelled \nmean"), size = 4) +
  geom_errorbar(data = emm_df, aes(x = code, ymin = lower.CL, ymax = upper.CL, 
                                   colour = "confidence \nlimits"), width = 0.2, lwd=1)+
  #stat_pvalue_manual(p_values, label = "signif")+
  geom_text(data = emm_df, aes(x = code, y = 950, #winter 400 summer 950
                               label = sprintf("paste(bar(m), ' = ', %s)", round(emmean,0))),
            size = 5, parse =TRUE)+
  geom_text(data = n_df, aes(x = code, y = y, label = label), size = 5)

