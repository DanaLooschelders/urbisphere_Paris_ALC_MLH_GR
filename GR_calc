    datename <- as.character(gsub("-", "", datum))
    setwd(paste0(archive_dir, "/", i, "/"))
    print(i)
    files <- list.files(pattern=paste0(datename, "T000000_"), recursive=T)
    file <- files[grepl("version(v1.0.2)", files, fixed=T)]
    if(length(file)>1){file <- file[2]}else{}
    if(i=="PABOBI"){height=3
    }else if(i=="PAROIS"){height=4
    }else if(i=="PASIRT"){height=4.5
    }else if(i=="PACHEM"){height=51
    }else{height=0}
    bsc <- alc_read_l1(file, var="rcs_0", offset = height, time_res = "1 min", #15 s
                       range_max = maxrange)
    mlh <- subset(all_MLH, ID==substr(i, start=3, stop=8)& date==as.Date(datum))
    sunt <- subset(site_suntime, ID==i & date == datum)
    res_sub <- res_GR[res_GR$Site==substr(i, start=3, stop=7)&as.Date(res_GR$Date)==as.Date(datum),]
    pred_sub <- subset(all_MLH_pred, ID==substr(i, start=3, stop=8) & date==as.POSIXct(datum, tz="UTC"))

    #plot
    p <- ggplot(data=bsc, aes(time, as.numeric(range)))+
      geom_tile(aes(fill=rcs_0))+
      geom_point(data=mlh, aes(x=time, y=MLH, color="MLH"))+
      ylab("Height agl [m]")+ xlab("Time [UTC]")+
      scale_fill_viridis_c(name= expression(atop("log(" ~beta ~") "  , (m^-1~sr^-1))), 
                           na.value = "grey", limits = c(10^-7, 10^-5), #option = "mako", 3*10^-6
                           oob = censor, trans = "log10", n.breaks = 7, direction=-1)+
      geom_line(data=pred_sub, aes(time, fit), color="red")+
      scale_color_manual("", values="red")+
      geom_vline(xintercept = as.POSIXct(res_sub$MT_start, tz="UTC"),
                 color="black")+
      geom_vline(xintercept = as.POSIXct(res_sub$MT_end, tz="UTC"),
                 color="black")+
      annotate("text", label="MT start", x=as.POSIXct(res_sub$MT_start, tz="UTC")+100, y=maxrange)+
      annotate("text", label="MT end", x=as.POSIXct(res_sub$MT_end, tz="UTC")+100, y=maxrange)+
      geom_vline(xintercept = as.POSIXct(res_sub$t_max_GR, tz="UTC"),
                 color="blue")+
      annotate("text", label=paste0("avg GR: ", round(res_sub$avg_GR, 0)), x=as.POSIXct(bsc$time[2], tz="UTC"), 
               y=maxrange)+
      annotate("text", label=paste0("max GR: ", round(res_sub$max_GR, 0)), 
               x=as.POSIXct(res_sub$t_max_GR, tz="UTC")+100, y=maxrange-100, color="blue")+
      geom_vline(xintercept = as.POSIXct(paste0(sunt$date, " ", 
                                                sunt$sunrise), tz="UTC"), color="grey")+
      annotate("text", label="SR", x=as.POSIXct(paste0(sunt$date, " ", 
                                                       sunt$sunrise), tz="UTC")+100, y=maxrange, color="grey")+
      geom_vline(xintercept = as.POSIXct(paste0(sunt$date, " ", 
                                                sunt$solarNoon), tz="UTC"),
                 color="grey", linetype="dashed")+
      geom_vline(xintercept = as.POSIXct(paste0(sunt$date, " ", 
                                                sunt$sunset), tz="UTC"),
                 color="grey")+
      annotate("text", label="SS", x=as.POSIXct(paste0(sunt$date, " ", 
                                                       sunt$sunset), tz="UTC")+100, y=maxrange, color="grey")+
      theme_bw()+theme(text = element_text(size=15), legend.key.size = unit(1, 'cm'))+
      ylim(0,maxrange)#+
    #xlim(as.POSIXct("2023-06-04 21:00:00", tz="UTC"), as.POSIXct("2023-06-05 00:00:00", tz="UTC"))
    
    ggsave(p, path= output_dir, filename= paste0("/MLH/case_study_days_mlh_stats_bsc/curve_fit_threshold/", 
                                                 datum, "_", i, "_Bsc_MLH_Stats_low.png"), 
           width=30, height=15, units="cm") #save 
  }
}

