#numerical
x_grid <- test$index
y_fit <- test$fit

# Compute numerical derivative
dy_dx <- diff(y_fit) / diff(x_grid)

#plot derivative
png(filename=paste0(output_dir, "/MLH/GR/", datename,"_",x,"_derivative_MT.png"), 
