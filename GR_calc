library(boot)
bootstrap_median <- function(x, R = 10000) {
  x <- x[!is.na(x)]  # remove NAs
  if(length(x) < 2){   # not enough data to bootstrap
    return(c(median = median(x), lower = NA, upper = NA))}
  boot_res <- boot(x, statistic = function(data, ind) median(data[ind]), R = R)
  ci <- boot.ci(boot_res, type = "perc")$percent[4:5]  # lower & upper CI
  return(c(median = median(x), lower = ci[1], upper = ci[2]))}

