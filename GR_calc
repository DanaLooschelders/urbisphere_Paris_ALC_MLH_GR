if(i=="2024-01-27"&x=="SIRT"){
#check for drops 
# Define the percentage threshold for allowable drop (e.g., 10%)
drop_threshold <- 0.05   # 5% of total growth
# Calculate total growth
total_growth <- max(test$MLH, na.rm = TRUE) - min(test$MLH, na.rm = TRUE)
# Remove where MLH drops
test <- test %>% arrange(index) %>%
  mutate(diff = MLH - lag(MLH)) %>%
  filter(is.na(diff) | diff > -drop_threshold * total_growth) %>%
  select(-diff)
}else{}
#define starting values
A0 <- min(test$MLH, na.rm = TRUE)
K0 <- max(test$MLH, na.rm = TRUE)*1.05 ##2#
# where y crosses halfway
midY <- (A0 + K0) / 2
# find time nearest midY
M0 <- test$index[which.min(abs(test$MLH - midY))]
B0 <- 0.04 #  initial slope guess 0.04
v0 <- 1.5 # asymmetry parameter ##0.1#0.01#1.5

#determine threshold for normalised derivative
threshold_start <- 0.08 #0.08
threshold_end  <- 0.8 

#symmetrical fit <- nlsLM(MLH ~ A + (K - A) / (1 + exp(-B * (index - M))), 
 #            start = list(A = A0, K = K0, B = B0, M = M0), 
  #           data = test, control = nls.lm.control(maxiter = 200))

#Richards curve
fit <- try(nlsLM(MLH ~ A + (K - A)/((1 + nu * exp(-B * (index - M)))^(1/nu)),
                      start = list(A = A0, K = K0, B = B0, M = M0, nu = v0),
                      data = test, 
                      control = nls.lm.control(maxiter = 500)), 
    silent=TRUE)
if(inherits(fit, "try-error")){
      v0 <- 1e-06
      fit <- nlsLM(MLH ~ A + (K - A)/((1 + nu * exp(-B * (index - M)))^(1/nu)),
                   start = list(A = A0, K = K0, B = B0, M = M0, nu = v0),
