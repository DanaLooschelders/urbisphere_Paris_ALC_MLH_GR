#sum data
MLH_summary <- MLH_NE_summer %>%
  group_by(ID, tod) %>%
  summarize(
    median_MLH = median(MLH, na.rm = TRUE),
    Q1 = quantile(MLH, 0.25, na.rm = TRUE),
    Q3 = quantile(MLH, 0.75, na.rm = TRUE),
    N = sum(!is.na(MLH)),
    .groups = "drop")

ggplot(MLH_summary, aes(x = as.factor(tod), group = ID, color = ID)) +
  geom_ribbon(aes(ymin = Q1, ymax = Q3, fill = ID), alpha = 0.1, color = NA) +
  geom_line(aes(y = median_MLH, size = N), linetype = "solid") +  # fix linetype to "solid"
  scale_size(range = c(0.5, 2), name = "N Obs.") +
  xlab("Time [UTC]") + 
  ylab("MLH [m]") +
  annotate(geom = "text", x = "22:00", y = 2000, 
           label = paste0("Total N: ", length(cond_NE_few_summer$Date))) +
  guides(
    x = guide_axis(angle = 90),
    color = guide_legend(title = "ID"),  
    fill = guide_legend(title = "ID"),
    size = guide_legend(title = "# Observations")
  ) +
  theme_bw()
ggsave(path=output_dir, filename="MLH/aggregated/ID_nObs_NE_summer_MLH_median_IQR_shading.png", 
       width=25, height=15, units="cm")

