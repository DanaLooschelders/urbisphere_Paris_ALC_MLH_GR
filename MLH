  mutate(datetime_hour = floor_date(time, "hour")) %>%
  group_by(ID_label, datetime_hour) %>%
  summarise(MLH = median(MLH, na.rm = TRUE), .groups = "drop")

MLH_hourly <- MLH_hourly %>%
  group_by(datetime_hour) %>%
  mutate(ref_MLH = MLH[ID_label == "upwind rural"]) %>%
  ungroup()  %>%
  mutate(rel_diff = (MLH - ref_MLH) / ref_MLH)  %>%
  mutate(tod_hms = hour(datetime_hour))

#aggregate rel diff for time of day 
X <- 0.5  # minimum fraction of non-NA data required
diurnal_median <- MLH_hourly %>%
  group_by(ID_label, tod_hms) %>%
  summarise(
    n_total = 7, n_valid = sum(!is.na(rel_diff)), frac_valid = n_valid / n_total,
    median_diff = ifelse(frac_valid >= X, median(rel_diff, na.rm = TRUE), NA_real_),
    .groups = "drop")

diurnal_median$tod_hms  <-  hms::hms(hours = diurnal_median$tod_hms)
str(diurnal_median)

diurnal_median %>% subset(tod_hms>=hms::as.hms("09:00:00")&
                            tod_hms<= hms::as.hms("17:00:00")&
                            frac_valid>0.5) %>% 
  group_by(ID_label) %>% summarise(median(median_diff*100, na.rm=T))

diurnal_median %>% subset(tod_hms>=hms::as.hms("20:00:00")|
