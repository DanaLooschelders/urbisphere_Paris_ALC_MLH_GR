#plot case study days
plotCaseDay  <- function(data=cond, name="cond", label="SW"){
  for(i in 1:dim(data)[1]){
    #subset data
    MLH_sub <- subset(all_MLH, date==data[i,1])
    if(length(MLH_sub)>0){
    datename <- as.character(gsub("-", "", substr(data[i,1], start=1, stop=10))) #for filename
    print(datename)
    #subset wind data for windrose
    eiffel_sub <- subset(eiffel, date==data[i,1])
    #plot windrose
    wr <- windrose(speed= eiffel_sub$ws, eiffel_sub$wd, ggtheme = "bw")
    wr <- wr+theme(legend.position="none")
    #get solar times
    suntimes_sub <- subset(suntimes, date==data[i,1])
    #plot sMLH
    plot_MLH <- ggplot(MLH_sub)+
      geom_line(aes(x=time, y=MLH, color=type, linetype=ID), na.rm=F)+
      geom_vline(xintercept = as.POSIXct(paste0(suntimes_sub$date, " ", 
                                                suntimes_sub$sunrise), tz="UTC"),
                 color="grey")+
      geom_vline(xintercept = as.POSIXct(paste0(suntimes_sub$date, " ", 
                                                suntimes_sub$solarNoon), tz="UTC"),
                 color="grey", linetype="dashed")+
      geom_vline(xintercept = as.POSIXct(paste0(suntimes_sub$date, " ", 
                                                suntimes_sub$sunset), tz="UTC"),
                 color="grey")+
      theme_bw()+xlab("Time [UTC]")+ylab("Mixed-layer height [m]")+
      inset_element(wr, left=-0.1, bottom=0.55, top=0.99, right=0.45)
    ggsave(plot_MLH, path=output_dir, 
           filename = paste0("/MLH/case_study_days/", label, "/", datename, "_MLH.png"), 
           width=25, height=15, units="cm")
    }else{}
  }
}


